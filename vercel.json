{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/app-integrada.html"
    },
    {
      "source": "/index.html",
      "destination": "/app-integrada.html"
    },
    {
      "source": "/.netlify/functions/iol-dashboard",
      "destination": "/api/iol-dashboard"
    },
    {
      "source": "/.netlify/functions/:path*",
      "destination": "/api/:path*"
    }
  ]
}
